# API Keys para serviços externos (substituídas por secrets no CI)
OPENAI_API_URL=https://openrouter.ai/api/v1
OPENAI_API_TOOL_NAME=Rapport Generativa Estatístico (Test)
OPENAI_API_KEY=${OPENAI_API_KEY:-test_key_placeholder}
OPENAI_MODEL=${OPENAI_MODEL:-gpt-4o-mini}
OPENAI_CODEX=${OPENAI_CODEX:-gpt-4o}
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# Configurações do Ollama (usando mock para testes)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mxbai-embed-large
# Outras opções de modelo:
# nomic-embed-text-v2-moe  (para português/multilíngue)
# bge-m3                   (para grandes acervos heterogêneos)

# ATENÇÃO: Uma vez criada a base de embeddings, não é possível trocar o modelo
# Para usar um modelo diferente, apague o diretório .data e recrie com o novo modelo

# Configurações do Conversor de Documentos
DATA_DIR=.data
CONVERTED_DIR=.data/converted
CHUNK_SIZE=100
CHUNK_OVERLAP=10
SIMILARITY_THRESHOLD=0.3

# Configurações de Banco de Dados (PostgreSQL para testes)
POSTGRES_DB=statistical-and-analytical-agentic_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-test_password}
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ChromaDB (para embeddings - usa diretório temporário em testes)
CHROMA_DB_PATH=.data/chroma_db_test

# Configurações de OCR
TESSERACT_LANG=eng
# Para outros idiomas: eng, spa, fra, etc.

# Paths para dependências externas (se necessário)
# TESSERACT_CMD=/usr/bin/tesseract
# POPPLER_PATH=/usr/bin
# DJVU_PATH=/usr/bin

# Modelos Ollama do agente estatístico
# Diretório onde estão os Modelfiles. Pode ser caminho absoluto (ex.: /opt/models)
# ou relativo (resolvido a partir do diretório onde o script está gravado).
MODELS_DIR=models
# Modelo estatístico (cientista: Karl Pearson)
STATS_MODEL_NAME=Rapport-Generativa-Pearson
STATS_MODELFILE=Pearson
# Modelo refinador de prompts
REFINER_MODEL_NAME=Rapport-Generativa-PromptRefiner
REFINER_MODELFILE=PromptRefiner

# Configurações específicas para testes
GENAI_GUI=0
LOG_LEVEL=DEBUG
TESTING_MODE=1

