# API Keys para serviços externos
# Se OPENAI_API_URL não for informado, usa a API da OpenAI diretamente
# Se informado, identifica automaticamente o provedor (OpenRouter, OpenAI, etc)
OPENAI_API_URL=https://openrouter.ai/api/v1
OPENAI_API_TOOL_NAME=Rapport Generativa Estatístico
OPENAI_API_KEY=sk-or-v1-SUA_CHAVE_AQUI
OPENAI_MODEL=GPT-5.4-mini
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto

# Configurações do Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mxbai-embed-large
# Outras opções de modelo:
# nomic-embed-text-v2-moe  (para português/multilíngue)
# bge-m3                   (para grandes acervos heterogêneos)

# ATENÇÃO: Uma vez criada a base de embeddings, não é possível trocar o modelo
# Para usar um modelo diferente, apague o diretório .data e recrie com o novo modelo

# Modelos Ollama do agente estatístico
# Diretório onde estão os Modelfiles. Pode ser caminho absoluto (ex.: /opt/models)
# ou relativo (resolvido a partir do diretório onde o script está gravado).
MODELS_DIR=models
# Modelo estatístico (cientista: Karl Pearson)
STATS_MODEL_NAME=Rapport-Generativa-Pearson
STATS_MODELFILE=Pearson
# Modelo refinador de prompts
REFINER_MODEL_NAME=Rapport-Generativa-PromptRefiner
REFINER_MODELFILE=PromptRefiner

# Configurações do Conversor de Documentos
DATA_DIR=~/.generativa/.data
CONVERTED_DIR=~/workspace/Faculdades e Cursos/GemeosDigitais/Livros e Apostilas/converteds
CHUNK_SIZE=500
CHUNK_OVERLAP=50
SIMILARITY_THRESHOLD=0.3

# Configurações de Banco de Dados
# PostgreSQL (único backend suportado — SQLite foi removido do projeto)
POSTGRES_DB=agente_estatistico
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ChromaDB (para embeddings)
CHROMA_DB_PATH=.data/chroma_db

# Configurações de OCR
TESSERACT_LANG=eng
# Para outros idiomas: eng, spa, fra, etc.

# Paths para dependências externas (se necessário)
# TESSERACT_CMD=/usr/bin/tesseract
# POPPLER_PATH=/usr/bin

# -----------------------------------------------------------------------------
# Universal Dataset Loader (UDL)
# -----------------------------------------------------------------------------
# Tracking de problemas de carga (linhas malformadas, valores coergidos a NaN,
# colunas que viraram nulls). Quando ativo, cada problema é registrado no
# InsertionJournal (PostgreSQL) com a linha, coluna, valor original e estratégia
# de correção. Modos: 'off' (sem registro) | 'full' (registra cada ocorrência).
# Em modo 'full' o pandas usa engine='python' (mais lento) para capturar
# linhas malformadas via callable on_bad_lines.
UDL_JOURNAL_TRACKING=full
# Limite de registros por chunk (0 = sem limite). Útil para datasets enormes
# onde gravar milhões de correções individuais é caro.
UDL_JOURNAL_MAX_PER_CHUNK=0
# DJVU_PATH=/usr/bin